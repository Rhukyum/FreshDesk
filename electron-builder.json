{
  "appId": "com.freshdesk.repair",
  "productName": "FreshDesk",
  "copyright": "MIT",
  "directories": {
    "output": "release"
  },
  "files": [
    "out/**/*"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "requestedExecutionLevel": "requireAdministrator"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "shortcutName": "FreshDesk"
  },
  "publish": {
    "provider": "github",
    "owner": "Rhukyum",
    "repo": "FreshDesk"
  }
}
