{
  "appId": "com.freshdesk.repair",
  "productName": "FreshDesk",
  "copyright": "Copyright © 2024 Rhukyum",
  "artifactName": "FreshDesk-Setup-${version}.${ext}",
  "directories": {
    "output": "release"
  },
  "files": [
    "out/**/*"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "requestedExecutionLevel": "requireAdministrator",
    "publisherName": "Rhukyum",
    "verifyUpdateCodeSignature": false
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "shortcutName": "FreshDesk",
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "installerHeaderIcon": "resources/icon.ico",
    "uninstallerIcon": "resources/icon.ico"
  },
  "publish": {
    "provider": "github",
    "owner": "Rhukyum",
    "repo": "FreshDesk"
  }
}
